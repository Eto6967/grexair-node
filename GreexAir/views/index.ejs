<!DOCTYPE html>
<html lang="hu" data-theme="dark">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>GrexAir · Demo</title>
  <link rel="icon" type="image/png" href="/static/logo.png">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Geist:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/grexair.css">
  <script src="/static/js/theme.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
<div id="preloader"><div class="pl-wrap"><img src="/static/logo.png" class="pl-logo" alt="" onerror="this.style.display='none'"><div class="pl-bar"><div class="pl-bar-fill"></div></div></div></div>
<div class="aurora"><div class="ao ao1"></div><div class="ao ao2"></div><div class="ao ao3"></div><div class="ao ao4"></div></div>
<div class="grain"></div>
<nav class="gx-nav">
  <a href="/" class="nav-brand"><div class="nav-logo-wrap"><img src="/static/logo.png" alt="GrexAir" onerror="this.outerHTML='<span style=&quot;color:#fff;font-size:10px;font-weight:800&quot;>CO₂</span>'"></div><div><div class="nav-brand-name">GrexAir</div><div class="nav-brand-tagline">CO₂ Monitor</div></div></a>
  <div class="nav-links">
    <a href="/" class="nav-link"><i class="fas fa-chart-line" style="font-size:10px;margin-right:4px"></i>Monitor</a>
    <a href="/demo" class="nav-link active"><i class="fas fa-play-circle" style="font-size:10px;margin-right:4px"></i>Demo</a>
    <a href="/upload" class="nav-link"><i class="fas fa-upload" style="font-size:10px;margin-right:4px"></i>Feltöltés</a>
  </div>
  <div class="nav-right"><button class="theme-btn" id="theme-toggle"><i class="fas fa-sun" id="theme-icon"></i></button></div>
</nav>
<div class="gx-page">
  <div class="gx-hero gx-a0"><div><h1>Demo Nézet</h1><div class="gx-hero-sub"><i class="fas fa-database" style="color:var(--green);font-size:9px"></i>SENSOR.CSV archív adatsor</div></div></div>
  <% if (payload) { %>
  <div class="gx-kpi-grid gx-a1">
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--blue)"><div class="kpi-card-top"><span class="kpi-label">Utolsó</span><div class="kpi-icon" style="background:var(--blue-d)">🌡</div></div><div class="kpi-val" style="color:var(--blue)"><%= payload.kpi.current %><span class="kpi-unit"> ppm</span></div><div class="kpi-sub">CO₂</div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--pur)"><div class="kpi-card-top"><span class="kpi-label">Átlag</span><div class="kpi-icon" style="background:var(--pur-d)">📊</div></div><div class="kpi-val" style="color:var(--pur)"><%= payload.kpi.avg %><span class="kpi-unit"> ppm</span></div><div class="kpi-sub">Teljes átlag</div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--red)"><div class="kpi-card-top"><span class="kpi-label">Maximum</span><div class="kpi-icon" style="background:var(--red-d)">⬆</div></div><div class="kpi-val" style="color:var(--red)"><%= payload.kpi.max %><span class="kpi-unit"> ppm</span></div><div class="kpi-sub">Csúcsérték</div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--green)"><div class="kpi-card-top"><span class="kpi-label">Minimum</span><div class="kpi-icon" style="background:var(--green-d)">⬇</div></div><div class="kpi-val" style="color:var(--green)"><%= payload.kpi.min %><span class="kpi-unit"> ppm</span></div><div class="kpi-sub">Legkisebb</div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--teal)"><div class="kpi-card-top"><span class="kpi-label">Tartomány</span><div class="kpi-icon" style="background:var(--teal-d)">↕</div></div><div class="kpi-val" style="color:var(--teal)"><%= payload.kpi.max-payload.kpi.min %><span class="kpi-unit"> ppm</span></div><div class="kpi-sub">Max−Min</div></div>
  </div>
  <div class="gx-status-row gx-a2">
    <div class="air-status-box <%= payload.air_status_class %>"><%= payload.air_status_text %></div>
    <div class="last-update-pill"><i class="fas fa-archive" style="font-size:9px;opacity:.6"></i>Archívum · <span style="color:var(--t1);font-weight:500"><%= payload.timestamp %></span></div>
  </div>
  <div class="gx-row cols-1 gx-a3"><div class="gx-card chart-wrap">
    <div class="chart-header"><div class="chart-title-block"><div class="chart-title-main">CO₂ Koncentráció</div><div class="chart-title-sub">Nyers + Savitzky-Golay</div></div></div>
    <div class="chart-h-xl"><canvas id="co2Chart"></canvas></div>
  </div></div>
  <div class="gx-row cols-3 gx-a4">
    <div class="gx-card chart-wrap"><div class="chart-header"><div class="chart-title-block"><div class="chart-title-main" style="--blue:#bf5af2">Sebesség</div><div class="chart-title-sub">ppm/perc</div></div></div><div class="chart-h-md"><canvas id="speedChart"></canvas></div></div>
    <div class="gx-card chart-wrap"><div class="chart-header"><div class="chart-title-block"><div class="chart-title-main" style="--blue:#ff9f0a">Gyorsulás</div><div class="chart-title-sub">Δ sebesség</div></div></div><div class="chart-h-md"><canvas id="accelChart"></canvas></div></div>
    <div class="gx-card chart-wrap"><div class="chart-header"><div class="chart-title-block"><div class="chart-title-main" style="--blue:#30d158">Eloszlás</div><div class="chart-title-sub">percek</div></div></div><div class="chart-h-md"><canvas id="timeBarChart"></canvas></div></div>
  </div>
  <script>const DEMO_PAYLOAD=<%- JSON.stringify(payload) %>;</script>
  <script src="/static/js/main.js"></script>
  <% } else { %>
  <div class="gx-card chart-wrap gx-a1" style="text-align:center;padding:60px 32px"><div style="font-size:36px;margin-bottom:12px;opacity:.4">📂</div><div style="font-size:15px;font-weight:700;margin-bottom:6px">Nincs demo adat</div><div style="font-size:12px;color:var(--t3)">A SENSOR.CSV fájl nem található.</div></div>
  <% } %>
</div>
</body>
</html>
