<!DOCTYPE html>
<html lang="hu" data-theme="dark">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>GrexAir · CSV Feltöltés</title>
  <link rel="icon" type="image/png" href="/static/logo.png">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Geist:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/grexair.css">
  <script src="/static/js/theme.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
<div id="preloader"><div class="pl-wrap"><img src="/static/logo.png" class="pl-logo" alt="" onerror="this.style.display='none'"><div class="pl-bar"><div class="pl-bar-fill"></div></div></div></div>
<div class="aurora"><div class="ao ao1"></div><div class="ao ao2"></div><div class="ao ao3"></div><div class="ao ao4"></div></div>
<div class="grain"></div>
<nav class="gx-nav">
  <a href="/" class="nav-brand"><div class="nav-logo-wrap"><img src="/static/logo.png" alt="GrexAir" onerror="this.outerHTML='<span style=&quot;color:#fff;font-size:10px;font-weight:800&quot;>CO₂</span>'"></div><div><div class="nav-brand-name">GrexAir</div><div class="nav-brand-tagline">CO₂ Monitor</div></div></a>
  <div class="nav-links">
    <a href="/" class="nav-link"><i class="fas fa-chart-line" style="font-size:10px;margin-right:4px"></i>Monitor</a>
    <a href="/demo" class="nav-link"><i class="fas fa-play-circle" style="font-size:10px;margin-right:4px"></i>Demo</a>
    <a href="/upload" class="nav-link active"><i class="fas fa-upload" style="font-size:10px;margin-right:4px"></i>Feltöltés</a>
  </div>
  <div class="nav-right"><button class="theme-btn" id="theme-toggle"><i class="fas fa-sun" id="theme-icon"></i></button></div>
</nav>
<div class="gx-page"><div class="gx-upload-page">
  <div class="gx-hero gx-a0"><div><h1>CSV Feltöltés</h1><div class="gx-hero-sub"><i class="fas fa-upload" style="font-size:9px"></i>Archív CO₂ adatok elemzése</div></div></div>
  <a href="/" class="back-link gx-a0"><i class="fas fa-arrow-left" style="font-size:10px"></i>Vissza</a>
  <div class="info-box gx-a1"><i class="fas fa-info-circle" style="color:var(--blue);margin-right:6px"></i>Tölts fel egy <strong>.CSV fájlt</strong>. Szükséges: <strong>időbélyeg</strong> (Ido/time/date) és <strong>CO₂</strong> (CO2_ppm/co2/ppm) oszlop. Elválasztó automatikusan felismert.</div>
  <% if (error) { %><div class="error-box gx-a1"><i class="fas fa-exclamation-triangle"></i><%= error %></div><% } %>
  <div class="gx-card gx-a2" style="padding:26px;margin-bottom:22px">
    <form action="/upload" method="POST" enctype="multipart/form-data">
      <div class="drop-zone" id="drop-zone"><div class="drop-icon">📄</div><div class="drop-title">Válassz vagy húzz ide CSV fájlt</div><div class="drop-sub">Támogatott: .csv · vessző vagy pontosvessző</div><input type="file" name="file" accept=".csv" required id="file-input"><div class="file-chosen" id="file-chosen"></div></div>
      <button type="submit" class="upload-btn"><i class="fas fa-chart-line" style="margin-right:8px"></i>Elemzés indítása</button>
    </form>
  </div>
  <% if (payload) { %>
  <div class="sec-label gx-a3">Elemzés eredménye</div>
  <div class="gx-kpi-grid gx-a3">
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--blue)"><div class="kpi-card-top"><span class="kpi-label">Utolsó</span></div><div class="kpi-val" style="color:var(--blue)"><%= payload.kpi.current %><span class="kpi-unit"> ppm</span></div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--pur)"><div class="kpi-card-top"><span class="kpi-label">Átlag</span></div><div class="kpi-val" style="color:var(--pur)"><%= payload.kpi.avg %><span class="kpi-unit"> ppm</span></div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--red)"><div class="kpi-card-top"><span class="kpi-label">Maximum</span></div><div class="kpi-val" style="color:var(--red)"><%= payload.kpi.max %><span class="kpi-unit"> ppm</span></div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--green)"><div class="kpi-card-top"><span class="kpi-label">Minimum</span></div><div class="kpi-val" style="color:var(--green)"><%= payload.kpi.min %><span class="kpi-unit"> ppm</span></div></div>
    <div class="gx-card kpi-card hoverable" style="border-top:2px solid var(--teal)"><div class="kpi-card-top"><span class="kpi-label">Tartomány</span></div><div class="kpi-val" style="color:var(--teal)"><%= payload.kpi.max-payload.kpi.min %><span class="kpi-unit"> ppm</span></div></div>
  </div>
  <div class="gx-card chart-wrap gx-a4" style="margin-bottom:12px">
    <div class="chart-header"><div class="chart-title-block"><div class="chart-title-main">CO₂ Koncentráció</div><div class="chart-title-sub">Nyers + Savitzky-Golay</div></div></div>
    <div class="chart-h-xl"><canvas id="co2Chart"></canvas></div>
  </div>
  <div class="gx-row cols-3 gx-a5">
    <div class="gx-card chart-wrap"><div class="chart-header"><div class="chart-title-block"><div class="chart-title-main" style="--blue:#bf5af2">Sebesség</div></div></div><div class="chart-h-md"><canvas id="speedChart"></canvas></div></div>
    <div class="gx-card chart-wrap"><div class="chart-header"><div class="chart-title-block"><div class="chart-title-main" style="--blue:#ff9f0a">Gyorsulás</div></div></div><div class="chart-h-md"><canvas id="accelChart"></canvas></div></div>
    <div class="gx-card chart-wrap"><div class="chart-header"><div class="chart-title-block"><div class="chart-title-main" style="--blue:#30d158">Eloszlás</div></div></div><div class="chart-h-md"><canvas id="timeBarChart"></canvas></div></div>
  </div>
  <script>const DEMO_PAYLOAD=<%- JSON.stringify(payload) %>;</script>
  <script src="/static/js/main.js"></script>
  <% } %>
</div></div>
<script>
document.getElementById('file-input').onchange=function(){document.getElementById('file-chosen').textContent=this.files[0]?'📎 '+this.files[0].name:''};
var dz=document.getElementById('drop-zone');
dz.addEventListener('dragover',function(e){e.preventDefault();dz.classList.add('drag-over')});
dz.addEventListener('dragleave',function(){dz.classList.remove('drag-over')});
dz.addEventListener('drop',function(e){e.preventDefault();dz.classList.remove('drag-over');var f=e.dataTransfer.files;if(f.length){document.getElementById('file-input').files=f;document.getElementById('file-chosen').textContent='📎 '+f[0].name;}});
</script>
</body>
</html>
